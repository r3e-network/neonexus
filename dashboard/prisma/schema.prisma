generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("member")
  accounts      Account[]
  sessions      Session[]
  
  // Custom: Link to an Organization
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// NeoNexus Core Models
model Organization {
  id                 String     @id @default(uuid())
  name               String
  billingPlan        String     @default("developer")
  stripeCustomerId   String?
  createdAt          DateTime   @default(now())
  
  users              User[]
  endpoints          Endpoint[]
  firewalls          Firewall[]
  apiKeys            ApiKey[]
  billingTransactions BillingTransaction[]
  provisioningOrders ProvisioningOrder[]
}

model ReconcileRun {
  id                        Int      @id @default(autoincrement())
  source                    String   @default("manual")
  status                    String
  provisioningChecked       Int
  provisioningResumed       Int
  alertingEndpointsEvaluated Int
  metadata                  Json?
  errorMessage              String?
  createdAt                 DateTime @default(now())
}

model Endpoint {
  id                Int       @id @default(autoincrement())
  organizationId    String?
  name              String
  protocol          String    @default("neo-n3")
  networkKey        String    @default("mainnet")
  network           String
  type              String
  clientEngine      String    @default("neo-go")
  syncMode          String    @default("full")
  settings          Json?
  url               String
  wssUrl            String?
  providerPublicIp  String?
  status            String    @default("Syncing")
  requests          Int       @default(0)
  cloudProvider     String?
  providerServerId  String?
  region            String?
  createdAt         DateTime  @default(now())
  organization      Organization? @relation(fields: [organizationId], references: [id])
  firewalls         Firewall[]
  plugins           NodePlugin[]
  secrets           NodeSecret[]
  alertRules        AlertRule[]
  alertIncidents    AlertIncident[]
  deliveryAttempts  AlertDeliveryAttempt[]
  activities        EndpointActivity[]
  provisioningOrders ProvisioningOrder[]
}

model EndpointActivity {
  id         Int       @id @default(autoincrement())
  endpointId Int
  category   String
  action     String
  status     String
  message    String
  metadata   Json?
  createdAt  DateTime  @default(now())
  endpoint   Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model NodePlugin {
  id          Int       @id @default(autoincrement())
  endpointId  Int
  pluginId    String    // e.g., "aa-bundler", "tee-oracle", "oracleService"
  status      String    @default("Installing") // Installing, Active, Error
  errorMessage String?
  lastAppliedAt DateTime?
  updatedAt   DateTime  @updatedAt
  config      Json?     // Store plugin-specific configuration like wallet addresses
  createdAt   DateTime  @default(now())
  endpoint    Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  
  @@unique([endpointId, pluginId])
}

model NodeSecret {
  id          Int       @id @default(autoincrement())
  endpointId  Int
  name        String    // e.g., "OraclePrivateKey", "BundlerKey"
  secretHash  String    // In production, this would be an AWS KMS ciphertext or HashiCorp Vault reference
  createdAt   DateTime  @default(now())
  endpoint    Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([endpointId, name])
}

model AlertRule {
  id          Int       @id @default(autoincrement())
  endpointId  Int
  name        String
  condition   String    // e.g., "status == 'Error'", "cpu > 80", "sync_lag > 100"
  actionType  String    // e.g., "email", "webhook"
  target      String    // Email address or Webhook URL
  isActive    Boolean   @default(true)
  deliveryAttemptCount Int @default(0)
  nextDeliveryAt DateTime?
  snoozedUntil DateTime?
  lastTriggeredAt DateTime?
  lastDeliveredAt DateTime?
  lastResolvedAt DateTime?
  lastDeliveryError String?
  createdAt   DateTime  @default(now())
  endpoint    Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  incidents   AlertIncident[]
  deliveryAttempts AlertDeliveryAttempt[]
}

model AlertIncident {
  id            Int       @id @default(autoincrement())
  alertRuleId   Int
  endpointId    Int
  status        String
  severity      String
  message       String
  openedAt      DateTime  @default(now())
  resolvedAt    DateTime?
  lastDeliveredAt DateTime?
  lastDeliveryError String?
  alertRule     AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  endpoint      Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model AlertDeliveryAttempt {
  id            Int       @id @default(autoincrement())
  alertRuleId   Int
  endpointId    Int
  actionType    String
  target        String
  status        String
  errorMessage  String?
  createdAt     DateTime  @default(now())
  alertRule     AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  endpoint      Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String?
  name           String
  keyHash        String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model BillingTransaction {
  id             Int          @id @default(autoincrement())
  organizationId String
  txHash         String       @unique
  plan           String
  amountAtomic   BigInt
  verifiedAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ProvisioningOrder {
  id             Int          @id @default(autoincrement())
  organizationId String
  endpointId     Int
  provider       String
  status         String
  currentStep    String
  attemptCount   Int          @default(0)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime?
  errorMessage   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endpoint       Endpoint     @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model Firewall {
  id          Int       @id @default(autoincrement())
  organizationId String
  endpointId  Int?
  type        String
  value       String
  createdAt   DateTime  @default(now())
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endpoint    Endpoint? @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}
